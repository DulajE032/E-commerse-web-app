{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/(public)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(public)/layout.js"
    ],
    "/(public)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(public)/page.css",
      "static/chunks/app/(public)/page.js"
    ],
    "/(public)/wishlist/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(public)/wishlist/page.js"
    ],
    "/(public)/product/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(public)/product/[id]/page.js"
    ]
  }
}